# ============================================
# AGENDO - Unified .gitignore
# ============================================

# ============================================
# General
# ============================================
.DS_Store
Thumbs.db
*.log
*.swp
*.swo
*~

# ============================================
# IDEs and Editors
# ============================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs (PhpStorm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
.fleet/
.zed/
.nova/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# Laravel Backend (PHP)
# ============================================
# Environment files
backend/backend/.env
backend/backend/.env.backup
backend/backend/.env.production

# Dependencies
backend/backend/vendor/
backend/backend/node_modules/

# Laravel specific
backend/backend/.phpactor.json
backend/backend/.phpunit.result.cache
backend/backend/.phpunit.cache
backend/backend/auth.json
backend/backend/Homestead.json
backend/backend/Homestead.yaml

# Storage
backend/backend/storage/*.key
backend/backend/storage/pail
backend/backend/public/storage
backend/backend/public/build
backend/backend/public/hot

# ============================================
# React Frontend (Node.js)
# ============================================
# Dependencies
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Build outputs
frontend/build/
frontend/.next/
frontend/out/

# Logs
frontend/logs
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Testing
frontend/coverage/
frontend/.nyc_output/

# ============================================
# Root Level
# ============================================
# Dependencies
/node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Lock files (uncomment if you want to ignore them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ============================================
# Databases
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
# Temporary files
# ============================================
*.tmp
*.temp
.cache/
.temp/
tmp/
temp/

# ============================================
# Documentation (keep generated docs)
# ============================================
# Add any documentation you want to ignore here
